[DB Query] {
  text: '\n' +
    '            SELECT \n' +
    '                e.id, \n' +
    '                e.first_name as "firstName", \n' +
    '                e.last_name as "lastName", \n' +
    '                e.email,\n' +
    '                e.primary_skills as "primarySkills", \n' +
    '                e.secondary_skills as "secondarySkills", \n' +
    '                e.current_project as "currentProject",\n' +
    '                e.billable_rate as "billableRate",\n' +
    '                e.expense_rate as "expenseRate",\n' +
    '                COALESCE(\n' +
    "                    STRING_AGG(DISTINCT p.name, ', ' ORDER BY p.name),\n" +
    "                    'Unassigned'\n" +
    '                ) as "projectName",\n' +
    '                COALESCE(\n' +
    '                    ROUND(\n' +
    '                        e.total_allocation_sum::numeric / \n' +
    '                        NULLIF(\n' +
    "                            (SELECT COUNT(DISTINCT DATE_TRUNC('month', start_date))\n" +
    '                             FROM core.allocations\n' +
    '                             WHERE employee_id = e.id), \n' +
    '                            0\n' +
    '                        )\n' +
    '                    )::integer,\n' +
    '                    e.total_allocation_sum\n' +
    '                ) as "allocation"\n' +
    '            FROM core.employees e\n' +
    '            LEFT JOIN core.allocations a ON e.id = a.employee_id AND a.end_date >= CURRENT_DATE\n' +
    '            LEFT JOIN core.projects p ON a.project_id = p.id\n' +
    '            GROUP BY e.id, e.first_name, e.last_name, e.email, e.primary_skills, e.secondary_skills, e.current_project, e.billable_rate, e.expense_rate, e.total_allocation_sum\n' +
    '            ORDER BY e.last_name, e.first_name\n' +
    '        ',
  duration: 1,
  rows: 4
}
