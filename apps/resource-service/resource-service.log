    '            LEFT JOIN core.projects p ON a.project_id = p.id\n' +
    '            GROUP BY e.id, e.first_name, e.last_name, e.email, e.primary_skills, e.secondary_skills, e.current_project, e.billable_rate, e.expense_rate, e.total_allocation_sum\n' +
