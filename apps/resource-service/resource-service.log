    '                   ARRAY_AGG(DISTINCT p.name) FILTER (WHERE p.name IS NOT NULL) as project_names,\n' +
    '                   ARRAY_AGG(DISTINCT r.name) FILTER (WHERE r.name IS NOT NULL) as roles\n' +
    '            FROM iam.users u\n' +
    '            LEFT JOIN iam.user_projects up ON u.username = up.username\n' +
    '            LEFT JOIN core.projects p ON up.project_id = p.id\n' +
    '            LEFT JOIN iam.user_roles ur ON u.username = ur.username\n' +
    '            LEFT JOIN iam.roles r ON ur.role_id = r.id\n' +
    '            GROUP BY u.username\n' +
    '            ORDER BY u.username\n' +
    '        ',
  duration: 3,
  rows: 3
}
